# EnDES - Variables de Entorno para Desarrollo Local
# Copia este archivo a .env y configura tus valores reales
# ¡NUNCA hagas commit del archivo .env!

# OpenAI API Key (OBLIGATORIA)
# Obtén tu API Key en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-tu-api-key-aqui

# Modelo de OpenAI (OPCIONAL - tiene valor por defecto)
OPENAI_MODEL_ID=gpt-5.1
